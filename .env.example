# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=core_finance

# URL formatted for PostgreSQL connection
DATABASE_URL=postgresql://user:password@db:5432/core_finance

# -----------------------------------------------------------------------------
# Cache Configuration
# -----------------------------------------------------------------------------
VALKEY_URL=valkey://valkey:6379

# -----------------------------------------------------------------------------
# Security Secrets
# -----------------------------------------------------------------------------
# Used for internal service-to-service communication
# To generate a strong key, run: openssl rand -hex 32
INTERNAL_API_KEY=dev-secret-key-123

# Used for signing user authentication tokens
# To generate a secure secret, run: openssl rand -base64 32
JWT_SECRET=super-secret-jwt-key-change-me-in-prod

# -----------------------------------------------------------------------------
# Docker Specific Overrides
# -----------------------------------------------------------------------------
DOCKER_DATABASE_URL=postgresql://user:password@db:5432/core_finance
DOCKER_VALKEY_URL=valkey://valkey:6379

# -----------------------------------------------------------------------------
# External APIs
# -----------------------------------------------------------------------------
# Get your Gemini API Key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# -----------------------------------------------------------------------------
# Domain Configuration
# -----------------------------------------------------------------------------
# Used for routing and callbacks. In production, change to your actual domain.
DOMAIN_NAME=localhost

# -----------------------------------------------------------------------------
# Web Push Notifications (VAPID Keys)
# -----------------------------------------------------------------------------
# Required for sending push notifications to browsers.
# To generate a new pair of VAPID keys, run the following command in your terminal:
# npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=YOUR_VAPID_PUBLIC_KEY_HERE
VAPID_PRIVATE_KEY=YOUR_VAPID_PRIVATE_KEY_HERE
